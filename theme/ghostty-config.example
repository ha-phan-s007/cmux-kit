# Ghostty config — used by both a standalone Ghostty install and by Cmux
# (Cmux is built on libghostty and reads this same file: `cmux reload-config`
# reloads it in place, no app restart needed).
#
# This example was generated from ONE person's macOS Terminal.app profile
# ("Clear Dark", 2026-07-07) so Cmux panes visually matched their existing
# Terminal.app theme/font. It is a reference, not a universal default —
# your own Terminal.app profile likely uses a different font/palette.
#
# To install as-is: copy to ~/.config/ghostty/config, then run `cmux reload-config`.
# Requires the "FiraCode Nerd Font" family installed (or edit font-family below
# to a font you already have — run `fc-list | grep -i <name>` to check).
#
# To regenerate this file from YOUR OWN Terminal.app profile instead, run:
#   python3 theme/extract-terminal-theme.py > ~/.config/ghostty/config
#   cmux reload-config

font-family = FiraCode Nerd Font  # verified family name via fc-list; PostScript name was FiraCodeNF-Reg
font-size = 12
font-thicken = true

background = #191d27
foreground = #e0e0e0
background-opacity = 0.95
selection-background = #273d4c
cursor-color = #e0e0e0

# ANSI 0-7 (normal) then 8-15 (bright), matching Terminal.app "Clear Dark"
palette = 0=#35424c
palette = 1=#b45648
palette = 2=#6caa71
palette = 3=#c4ac62
palette = 4=#6d96b4
palette = 5=#bd7bcd
palette = 6=#7ccbcd
palette = 7=#dee5eb
palette = 8=#465c6d
palette = 9=#df6c5a
palette = 10=#79be7e
palette = 11=#e5c872
palette = 12=#67b5ed
palette = 13=#d389e5
palette = 14=#84dde0
palette = 15=#e5eff5
